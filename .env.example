# SFDAP Environment Variables — Ornek
# Local development icin: cp .env.example .env (veya copy .env.example .env)
# Production icin tum *_KEY degerlerini ZORUNLU override edin.

# ─── Ortam ─────────────────────────────────────────────────
# development | staging | production
# Production'da default API_KEY/SECRET_KEY kullanimi engellenir (fail-fast).
ENVIRONMENT=development

# ─── Veritabani ────────────────────────────────────────────
# Dev: SQLite (varsayilan, calisir)
DATABASE_URL=sqlite:///./sfdap_dev.db
# Prod: PostgreSQL ornegi
# DATABASE_URL=postgresql://postgres:password@localhost:5432/sfdap_db

# Connection pool tuning (sadece PostgreSQL/MySQL'de aktif; SQLite no-op)
# shiftFinal Emirhan A4 — production'da prod yuku icin tune edilir
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_PRE_PING=True
DB_POOL_RECYCLE=3600

# ─── Backup/Restore (scripts/backup.sh icin) ──────────────
# BACKUP_DIR=./backups          # Default: ./backups
# RETENTION_DAYS=7               # Default: 7 gun (cron rotation)

# ─── HTTP sunucu ───────────────────────────────────────────
# Container/prod icin 0.0.0.0; local dev icin 127.0.0.1
API_HOST=127.0.0.1
API_PORT=8000
# Prod'da MUTLAKA False: True iken SQLAlchemy echo SQL+parametreleri (sifre hash/PII) loglar.
API_DEBUG=False

# ─── Kimlik dogrulama (PROD'DA ZORUNLU OVERRIDE) ──────────
# Yeni anahtar uretmek icin: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=your-secret-api-key-here
SECRET_KEY=your-secret-key-for-jwt

# ─── Dis servisler ─────────────────────────────────────────
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key

# ─── ML & dosya yollari ────────────────────────────────────
MODEL_PATH=app/ml/models/

# ─── MQTT (Cycle 7 — IoT sensor stream) ──────────────────
# MQTT_ENABLED=false iken listener no-op kalir (broker olmadan da
# uygulama calisir). Production icin true + erisilebilir broker gerek.
MQTT_ENABLED=false
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_CLIENT_ID=sfdap-listener

# ─── CORS ──────────────────────────────────────────────────
# Virgulle ayrilmis origin listesi (bosluk OK, otomatik trim).
CORS_ORIGINS=http://localhost:8000,http://localhost:3000,http://127.0.0.1:8000

# ─── Gözlemlenebilirlik (shiftFinal A2 — Mehmet) ──────────
# SENTRY_DSN bos kaldigi surece Sentry no-op'tur (dev/test default).
# Production icin Sentry projesinden alinacak DSN burada set edilir.
SENTRY_DSN=
# Bos birakilirsa ENVIRONMENT degerini kullanir.
SENTRY_ENVIRONMENT=
# 0.0 (kapali) - 1.0 (tum istekler). Production icin 0.1-0.2 onerilir.
SENTRY_TRACES_SAMPLE_RATE=0.1

# Loglama formati: text (renkli console, default) veya json (yapilandirilmis,
# production icin onerilir; ELK/Loki/CloudWatch parsing dostu).
LOG_FORMAT=text

# Prometheus metrics endpoint GET /metrics altinda otomatik aciktir,
# ek env gerektirmez. Cardinality kontrolu PrometheusMiddleware'da yapilir.

# ─── Production Deploy (nginx + Let's Encrypt) ────────────
# docker-compose.yml ve nginx/conf.d/default.conf.template tarafindan kullanilir.
# Local dev: DOMAIN=localhost yeterli (HTTPS cert'siz calismaz, bu da beklenen).
# Production: DOMAIN'i kendi domain'inize set edin ve Let's Encrypt cert alin.
# Detay: docs/setup/PROD_DEPLOY.md
DOMAIN=localhost
# certbot ilk sertifika alirken kullanilan iletisim e-posta'si (zorunlu):
EMAIL=admin@example.com

# PostgreSQL (sadece --profile postgres aktiveyse kullanilir)
POSTGRES_USER=sfdap_user
POSTGRES_PASSWORD=sfdap_password
POSTGRES_DB=sfdap_db
