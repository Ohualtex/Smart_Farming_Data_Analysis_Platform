# SFDAP Environment Variables — Ornek
# Local development icin: cp .env.example .env (veya copy .env.example .env)
# Production icin tum *_KEY degerlerini ZORUNLU override edin.

# ─── Ortam ─────────────────────────────────────────────────
# development | staging | production
# Production'da default API_KEY/SECRET_KEY kullanimi engellenir (fail-fast).
ENVIRONMENT=development

# ─── Veritabani ────────────────────────────────────────────
# Dev: SQLite (varsayilan, calisir)
DATABASE_URL=sqlite:///./sfdap_dev.db
# Prod: PostgreSQL ornegi
# DATABASE_URL=postgresql://postgres:password@localhost:5432/sfdap_db

# ─── HTTP sunucu ───────────────────────────────────────────
# Container/prod icin 0.0.0.0; local dev icin 127.0.0.1
API_HOST=127.0.0.1
API_PORT=8000
API_DEBUG=True

# ─── Kimlik dogrulama (PROD'DA ZORUNLU OVERRIDE) ──────────
# Yeni anahtar uretmek icin: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=your-secret-api-key-here
SECRET_KEY=your-secret-key-for-jwt

# ─── Dis servisler ─────────────────────────────────────────
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key

# ─── ML & dosya yollari ────────────────────────────────────
MODEL_PATH=app/ml/models/

# ─── MQTT (Cycle 7 — IoT sensor stream) ──────────────────
# MQTT_ENABLED=false iken listener no-op kalir (broker olmadan da
# uygulama calisir). Production icin true + erisilebilir broker gerek.
MQTT_ENABLED=false
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_CLIENT_ID=sfdap-listener

# ─── CORS ──────────────────────────────────────────────────
# Virgulle ayrilmis origin listesi (bosluk OK, otomatik trim).
CORS_ORIGINS=http://localhost:8000,http://localhost:3000,http://127.0.0.1:8000
